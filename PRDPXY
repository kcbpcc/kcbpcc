#!/bin/bash

# ---------------- Hushlogin & Symlink ----------------
touch ~/.hushlogin
sudo ln -s PRD/pxy pxy

# ---------------- Initialize summary variables ----------------
success_count=0
fail_count=0

# ---------------- Confirm Removal ----------------
read -p "Are you sure you want to remove ~/PRD/pxy? (y/n): " confirm
if [ "$confirm" = "y" ]; then
    if [ -d ~/PRD/pxy ]; then
        sudo rm -rf ~/PRD/pxy
        if [ $? -eq 0 ]; then
            echo -e "\e[32mRemoved ~/PRD/pxy: Success\e[0m"
            ((success_count++))
        else
            echo -e "\e[31mFailed to remove ~/PRD/pxy\e[0m"
            ((fail_count++))
            exit 1
        fi
    else
        echo "Directory ~/PRD/pxy not found, moving on."
    fi

    sudo rm -rf /usr/local/bin/pxy*
    if [ $? -eq 0 ]; then
        echo -e "\e[32mRemoved files in /usr/local/bin/: Success\e[0m"
        ((success_count++))
    else
        echo -e "\e[31mFailed to remove files in /usr/local/bin/\e[0m"
        ((fail_count++))
        exit 1
    fi
fi

# ---------------- User Setup ----------------
current_user=$(whoami)
usernames=("$current_user")
modified_successfully=false

for username in "${usernames[@]}"; do
    sudo usermod -aG sudo "$username"
    if [ $? -eq 0 ]; then
        echo -e "\e[32mUser modified successfully: $username\e[0m"
        ((success_count++))
        modified_successfully=true
        break
    else
        echo -e "\e[31mFailed to modify user: $username\e[0m"
    fi
done

if [ "$modified_successfully" = true ]; then

    # ---------------- System Packages ----------------
    sudo apt-get update
    sudo apt-get install -y multitail git python3-venv unzip python3-pip nodejs npm tmux
    if [ $? -eq 0 ]; then
        echo -e "\e[32mSystem packages installed/updated: Success\e[0m"
        ((success_count++))
    else
        echo -e "\e[31mFailed to install system packages\e[0m"
        ((fail_count++))
        exit 1
    fi

    # ---------------- SSH Key ----------------
    if [ ! -f ~/.ssh/id_rsa.pub ]; then
        ssh-keygen -t rsa -b 4096 -C "pxy.kcbpcc@gmail.com"
        cat ~/.ssh/id_rsa.pub
    else
        echo "SSH key already exists. Skipping generation."
    fi

    # ---------------- Git Clone ----------------
    read -p "Do you want to proceed with cloning repository? (y/n): " confirm
    if [ "$confirm" != "y" ]; then
        echo "Exiting script."
        exit 0
    fi

    git clone git@github.com:kcbpcc/PRD.git
    if [ $? -eq 0 ]; then
        echo -e "\e[32mCloned pxy repository successfully\e[0m"
        ((success_count++))
    else
        echo -e "\e[31mFailed to clone pxy repository\e[0m"
        ((fail_count++))
        exit 1
    fi

    sudo chmod -R 777 ~/PRD/pxy
    ((success_count++))

    # ---------------- Node.js Dependencies & Port Permissions ----------------
    echo -e "\nSetting up Node.js project environment..."
    if [ -d ~/PRD/pxy ]; then
        cd ~/PRD/pxy || exit 1
        
        # Check for pxy.json and copy it to package.json so npm works out of the box
        if [ -f "pxy.json" ]; then
            cp pxy.json package.json
            npm install
            if [ $? -eq 0 ]; then
                echo -e "\e[32mNode.js dependencies (express, ws) installed successfully\e[0m"
                ((success_count++))
            else
                echo -e "\e[31mFailed to install Node.js dependencies\e[0m"
                ((fail_count++))
            fi
        else
            echo -e "\e[33mWarning: pxy.json not found in ~/PRD/pxy. Skipping npm install.\e[0m"
        fi
        cd ~ || exit 1
    fi

    # Grant Node permission to use port 80 without sudo
    sudo setcap 'cap_net_bind_service=+ep' $(which node)
    if [ $? -eq 0 ]; then
        echo -e "\e[32mGranted Node.js capabilities to bind to low ports (e.g. Port 80)\e[0m"
        ((success_count++))
    else
        echo -e "\e[31mFailed to apply setcap capabilities to Node.js\e[0m"
        ((fail_count++))
    fi

    # ---------------- Copy executables to /usr/local/bin ----------------
    if [ -d ~/PRD/pxy/sys/p ]; then
        sudo cp -r ~/PRD/pxy/sys/p/* /usr/local/bin/
    fi

    copied_any=false
    for file in ~/PRD/pxy/*; do
        if [ -f "$file" ] && [[ "$file" != *.* ]]; then
            sudo cp "$file" /usr/local/bin/
            copied_any=true
        fi
    done

    if [ "$copied_any" = true ]; then
        echo -e "\e[32mCopied pxy executables without extension to /usr/local/bin/: Success\e[0m"
        ((success_count++))
        sudo chmod +x /usr/local/bin/*
    else
        echo -e "\e[33mNo files without extension found to copy to /usr/local/bin/\e[0m"
    fi

    # ---------------- Python Virtual Environment ----------------
    python3 -m venv env
    sudo chmod -R 777 env
    source ~/env/bin/activate
    pip install --upgrade pip

    # ---------------- Install Python Dependencies ----------------
    REQUIREMENTS=~/PRD/pxy/pxyinstl
    if [ -f "$REQUIREMENTS" ]; then
        pip install -r "$REQUIREMENTS"
        if [ $? -eq 0 ]; then
            echo -e "\e[32mInstalled Python dependencies: Success\e[0m"
            ((success_count++))
        else
            echo -e "\e[31mFailed to install Python dependencies\e[0m"
            ((fail_count++))
            exit 1
        fi
    else
        echo -e "\e[33m$REQUIREMENTS not found! Skipping Python dependency installation.\e[0m"
    fi

    # ---------------- Executable Final Compilation ----------------
    cd ~/PRD/pxy/sys/exe/run || exit 1
    pxypyc

    # ---------------- Force reinstall yfinance ----------------
    echo -e "\nReinstalling yfinance..."
    source ~/env/bin/activate
    pip uninstall -y yfinance
    if [ $? -eq 0 ]; then
        echo -e "\e[32mUninstalled yfinance successfully\e[0m"
    else
        echo -e "\e[33mWarning: yfinance may not have been installed\e[0m"
    fi

    pip install yfinance --upgrade
    if [ $? -eq 0 ]; then
        echo -e "\e[32mInstalled/Updated yfinance successfully\e[0m"
        ((success_count++))
    else
        echo -e "\e[31mFailed to install/update yfinance\e[0m"
        ((fail_count++))
    fi

    # ---------------- LOGON SETUPS & ENVIRONMENT CONFIGURATIONS ----------------
    echo -e "\nRunning final logon and user workspace adjustments..."

    # Create a staging copy of the repository's bashrc
    cp ~/PRD/pxy/sys/.bashrc /tmp/.pxy_bashrc

    # Append configurations directly into the staged bashrc file
    cat << 'EOF' >> /tmp/.pxy_bashrc

# Force session redirection directly into user home space
if [ "$PWD" != "$HOME" ]; then
    cd "$HOME"
fi

# Run pxygo EXACTLY ONCE per boot session
if [ ! -f "/dev/shm/pxygo_boot_done" ]; then
    if command -v pxygo >/dev/null 2>&1; then
        pxygo &
        touch "/dev/shm/pxygo_boot_done"
    fi
fi
EOF

    # Install updated bash environment configurations directly over the old one
    sudo cp /tmp/.pxy_bashrc ~/.bashrc
    rm -f /tmp/.pxy_bashrc

    if [ $? -eq 0 ]; then
        echo -e "\e[32mConfigured pxygo execution via .bashrc: Success\e[0m"
        ((success_count++))
    else
        echo -e "\e[31mFailed to configure auto-run updates in .bashrc\e[0m"
        ((fail_count++))
    fi

    # Explicit final landing instruction to drop script execution interface into home folder
    cd ~ || exit 1

    # ---------------- Summary ----------------
    echo -e "\nSummary:"
    echo -e "\e[32mSuccesses: $success_count\e[0m"
    echo -e "\e[31mFailures: $fail_count\e[0m"

else
    echo -e "\nWas NOT successful. Exiting script."
    exit 1
fi
