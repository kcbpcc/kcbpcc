#!/bin/bash

# ===============================
# User creation / admin setup
# ===============================

# Ask for username
read -p "Enter the username to create: " NEW_USER

# Ask for password (hidden input)
read -s -p "Enter the password for $NEW_USER: " NEW_PASS
echo

# Create user with home directory and bash shell
sudo useradd -m -s /bin/bash "$NEW_USER"

# Set user password
echo "$NEW_USER:$NEW_PASS" | sudo chpasswd

# Add user to sudo group (Debian/Ubuntu)
if [ -f /etc/debian_version ]; then
    sudo usermod -aG sudo "$NEW_USER"
fi

# Add user to wheel group (CentOS/RHEL/Fedora)
if [ -f /etc/redhat-release ]; then
    sudo usermod -aG wheel "$NEW_USER"
fi

echo "User $NEW_USER created successfully and given admin privileges."
echo "Home directory: /home/$NEW_USER"
echo "Switching to $NEW_USER to continue installation..."

# ===============================
# Switch to new user for setup
# ===============================
sudo -H -u "$NEW_USER" bash <<'EOF'

# Touch hushlogin
touch ~/.hushlogin

# Initialize counters
success_count=0
fail_count=0

# Remove old pxy if exists
if [ -d ~/pxy ]; then
    rm -rf ~/pxy && echo "Removed ~/pxy" && ((success_count++)) || ((fail_count++))
fi
sudo rm -rf /usr/local/bin/pxy* && ((success_count++)) || ((fail_count++))

# Update and install essentials
sudo apt-get update && sudo apt-get install -y multitail git python3-venv unzip || exit 1

# SSH key generation
if [ ! -f ~/.ssh/id_rsa.pub ]; then
    ssh-keygen -t rsa -b 4096 -C "pxy.kcbpcc@gmail.com" -f ~/.ssh/id_rsa -N ""
fi

# Clone pxy repository
git clone git@github.com:kcbpcc/$USER.git ~/pxy || exit 1
chmod -R 777 ~/pxy && ((success_count++)) || ((fail_count++))

# Copy executables to /usr/local/bin
sudo cp ~/pxy/sys/pxy* /usr/local/bin/
sudo chmod +x /usr/local/bin/pxy*

# Create Python virtual environment
python3 -m venv ~/env && chmod -R 777 ~/env

# Activate venv and install pip & dependencies
source ~/env/bin/activate
python3 -m pip install --upgrade pip
pip install -r ~/pxy/sys/exe/requirements.txt

# Copy .bashrc
cp ~/pxy/sys/.bashrc ~/.bashrc

# Navigate to run directory
cd ~/pxy/sys/exe/run

# Run pxypyc
pxypyc

# Summary
echo -e "\nSummary:"
echo -e "Successes: $success_count"
echo -e "Failures: $fail_count"

# ===============================
# Keep user in run directory and venv
# ===============================
echo "Setup complete. Staying in run directory with virtual environment activated."
exec bash --rcfile <(echo "source ~/env/bin/activate; cd ~/pxy/sys/exe/run; PS1='[\u@\h \W] \$ '")

EOF
