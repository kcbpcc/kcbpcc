#!/bin/bash

touch ~/.hushlogin

success_count=0
fail_count=0

echo "--------------------------------------"
read -p "Remove ~/V1L58/pxy and executables? (y/n): " confirm
echo "--------------------------------------"

if [ "$confirm" = "y" ]; then

    # Remove project directory (inside HOME → no sudo needed)
    if [ -d "$HOME/V1L58/pxy" ]; then
        rm -rf "$HOME/V1L58/pxy"
        if [ $? -eq 0 ]; then
            echo -e "\e[32mRemoved ~/V1L58/pxy\e[0m"
            ((success_count++))
        else
            echo -e "\e[31mFailed removing ~/V1L58/pxy\e[0m"
            ((fail_count++))
            exit 1
        fi
    fi

    # Remove ONLY files from /usr/local/bin
    sudo find /usr/local/bin -maxdepth 1 -type f -exec rm -f {} +
    if [ $? -eq 0 ]; then
        echo -e "\e[32mRemoved files from /usr/local/bin\e[0m"
        ((success_count++))
    else
        echo -e "\e[31mFailed cleaning /usr/local/bin\e[0m"
        ((fail_count++))
        exit 1
    fi
fi

# ----------------------------------
# Install Required Packages
# ----------------------------------

sudo apt-get update || exit 1
sudo apt-get install -y multitail git unzip python3-venv python3-pip || exit 1
((success_count++))

# ----------------------------------
# SSH Key
# ----------------------------------

if [ ! -f ~/.ssh/id_rsa.pub ]; then
    ssh-keygen -t rsa -b 4096 -C "pxy.kcbpcc@gmail.com"
    cat ~/.ssh/id_rsa.pub
fi

read -p "Continue with git clone? (y/n): " confirm
[ "$confirm" != "y" ] && exit 0

# ----------------------------------
# Clone Repository
# ----------------------------------

git clone git@github.com:kcbpcc/V1L58.git
if [ $? -eq 0 ]; then
    echo -e "\e[32mRepository cloned successfully\e[0m"
    ((success_count++))
else
    echo -e "\e[31mGit clone failed\e[0m"
    ((fail_count++))
    exit 1
fi

# ----------------------------------
# Copy Files to /usr/local/bin
# ----------------------------------

sudo find "$HOME/V1L58/pxy/sys" -maxdepth 1 -type f -exec cp -t /usr/local/bin/ {} +

if [ $? -eq 0 ]; then
    echo -e "\e[32mCopied executables to /usr/local/bin\e[0m"
    ((success_count++))
else
    echo -e "\e[31mFailed copying executables\e[0m"
    ((fail_count++))
    exit 1
fi

# ----------------------------------
# Set 777 Permissions (as requested)
# ----------------------------------

sudo find /usr/local/bin -maxdepth 1 -type f -exec chmod 777 {} +

if [ $? -eq 0 ]; then
    echo -e "\e[32mSet 777 permissions on executables\e[0m"
    ((success_count++))
else
    echo -e "\e[31mFailed setting permissions\e[0m"
    ((fail_count++))
    exit 1
fi

# ----------------------------------
# Python Virtual Environment
# ----------------------------------

python3 -m venv "$HOME/env"
if [ $? -eq 0 ]; then
    echo -e "\e[32mVirtual environment created\e[0m"
    ((success_count++))
else
    echo -e "\e[31mFailed creating virtual environment\e[0m"
    ((fail_count++))
    exit 1
fi

source "$HOME/env/bin/activate"

pip install --upgrade pip

cd "$HOME/V1L58/pxy/sys/exe" || exit 1
pip install -r requirements.txt

if [ $? -eq 0 ]; then
    echo -e "\e[32mInstalled Python dependencies\e[0m"
    ((success_count++))
else
    echo -e "\e[31mFailed installing dependencies\e[0m"
    ((fail_count++))
    exit 1
fi

# ----------------------------------
# Bash Config
# ----------------------------------

cp "$HOME/V1L58/pxy/sys/.bashrc" "$HOME/.bashrc"

# ----------------------------------
# Final Run
# ----------------------------------

cd "$HOME/V1L58/pxy/sys/exe/run" || exit 1
source "$HOME/env/bin/activate"

if command -v pxypyc >/dev/null 2>&1; then
    pxypyc
fi

# ----------------------------------
# Summary
# ----------------------------------

echo "--------------------------------------"
echo -e "\e[32mSuccesses: $success_count\e[0m"
echo -e "\e[31mFailures: $fail_count\e[0m"
echo "--------------------------------------"
