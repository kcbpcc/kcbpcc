#!/bin/bash

touch ~/.hushlogin

BASE_DIR="$HOME/V1L58"
PXY_DIR="$BASE_DIR/pxy"
RUN_DIR="$PXY_DIR/sys/exe/run"
ENV_DIR="$PXY_DIR/env"

success_count=0
fail_count=0

echo "Maintaining structure:"
echo "$PXY_DIR"
echo "$RUN_DIR"
echo ""

read -p "Remove existing ~/V1L58/pxy ? (y/n): " confirm
if [ "$confirm" = "y" ]; then
    sudo rm -rf "$PXY_DIR"
    sudo rm -rf /usr/local/bin/pxy*
fi

# -----------------------------
# System packages
# -----------------------------
sudo apt-get update
sudo apt-get install -y git multitail python3-venv python3-pip unzip

# -----------------------------
# Clone repository
# -----------------------------
cd "$HOME"
sudo git clone git@github.com:kcbpcc/V1L58.git

if [ $? -ne 0 ]; then
    echo "Clone failed"
    exit 1
fi

((success_count++))

# -----------------------------
# Give full permissions
# -----------------------------
sudo chmod -R 777 "$BASE_DIR"

# -----------------------------
# Create virtual environment
# -----------------------------
sudo python3 -m venv "$ENV_DIR"

if [ $? -ne 0 ]; then
    echo "Venv creation failed"
    exit 1
fi

sudo chmod -R 777 "$ENV_DIR"

((success_count++))

# -----------------------------
# Activate and install
# -----------------------------
source "$ENV_DIR/bin/activate"

sudo pip install --upgrade pip

cd "$PXY_DIR/sys/exe"
sudo pip install -r requirements.txt

if [ $? -ne 0 ]; then
    echo "Dependency install failed"
    exit 1
fi

((success_count++))

# -----------------------------
# Install pxy executables
# -----------------------------
sudo cp "$PXY_DIR/sys/pxy"* /usr/local/bin/
sudo chmod +x /usr/local/bin/pxy*
sudo chmod -R 777 /usr/local/bin/pxy*

((success_count++))

# -----------------------------
# Final permissions
# -----------------------------
sudo chmod -R 777 "$PXY_DIR"

# -----------------------------
# Go to run directory
# -----------------------------
cd "$RUN_DIR"

echo ""
echo "---------------------------------"
echo "STRUCTURE READY (777 MODE)"
echo "---------------------------------"
echo "Base     : $PXY_DIR"
echo "Run path : $RUN_DIR"
echo "Venv     : $ENV_DIR"
echo "---------------------------------"
echo "Success: $success_count"
echo "Fail   : $fail_count"
echo ""
