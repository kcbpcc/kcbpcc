#!/bin/bash

touch ~/.hushlogin

BASE_DIR="$HOME/V1L58"
PXY_DIR="$BASE_DIR/pxy"
RUN_DIR="$PXY_DIR/sys/exe/run"
ENV_DIR="$PXY_DIR/env"

success_count=0
fail_count=0

echo "======================================"
echo "Maintaining Structure:"
echo "$PXY_DIR"
echo "$RUN_DIR"
echo "======================================"

# ----------------------------------
# REMOVE OLD INSTALL
# ----------------------------------
read -p "Remove existing ~/V1L58/pxy ? (y/n): " confirm
if [ "$confirm" = "y" ]; then
    rm -rf "$PXY_DIR"
    sudo rm -rf /usr/local/bin/pxy*
fi

# ----------------------------------
# SYSTEM PACKAGES (sudo needed)
# ----------------------------------
sudo apt-get update
sudo apt-get install -y git multitail python3-venv python3-pip unzip

# ----------------------------------
# SSH KEY SETUP (user level)
# ----------------------------------
SSH_KEY="$HOME/.ssh/id_ed25519"

if [ ! -f "$SSH_KEY" ]; then
    echo "Generating SSH key..."
    ssh-keygen -t ed25519 -C "pxy.kcbpcc@gmail.com" -f "$SSH_KEY" -N ""
fi

eval "$(ssh-agent -s)"
ssh-add "$SSH_KEY"

echo ""
echo "======================================"
echo "COPY THIS KEY AND ADD TO GITHUB:"
echo "======================================"
cat "$SSH_KEY.pub"
echo "======================================"
echo ""
echo "Add it in GitHub → Settings → SSH & GPG keys"
read -p "Press ENTER after adding key..."

ssh -T git@github.com

# ----------------------------------
# CLONE REPO (NO sudo here)
# ----------------------------------
cd "$HOME"
git clone git@github.com:kcbpcc/V1L58.git

if [ $? -ne 0 ]; then
    echo "Clone failed"
    exit 1
fi

((success_count++))

# ----------------------------------
# PERMISSIONS (777 mode as requested)
# ----------------------------------
chmod -R 777 "$BASE_DIR"

# ----------------------------------
# CREATE VENV (NO sudo)
# ----------------------------------
python3 -m venv "$ENV_DIR"
chmod -R 777 "$ENV_DIR"

((success_count++))

# ----------------------------------
# INSTALL PYTHON DEPENDENCIES (NO sudo)
# ----------------------------------
source "$ENV_DIR/bin/activate"

pip install --upgrade pip

cd "$PXY_DIR/sys/exe"
pip install -r requirements.txt

if [ $? -ne 0 ]; then
    echo "Dependency install failed"
    exit 1
fi

((success_count++))

# ----------------------------------
# INSTALL EXECUTABLES (sudo needed)
# ----------------------------------
sudo cp "$PXY_DIR/sys/pxy"* /usr/local/bin/
sudo chmod +x /usr/local/bin/pxy*
sudo chmod -R 777 /usr/local/bin/pxy*

((success_count++))

# ----------------------------------
# FINAL STEP
# ----------------------------------
chmod -R 777 "$PXY_DIR"

cd "$RUN_DIR"
source "$ENV_DIR/bin/activate"

echo ""
echo "======================================"
echo "INSTALL COMPLETE"
echo "======================================"
echo "Base Directory : $PXY_DIR"
echo "Run Directory  : $RUN_DIR"
echo "Virtual Env    : $ENV_DIR"
echo "======================================"
echo "Success: $success_count"
echo "Fail   : $fail_count"
echo "======================================"
